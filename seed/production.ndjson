{"_id":"legal-privacy","_type":"legalPage","title":"Privacy","slug":{"_type":"slug","current":"privacy"},"body":[{"_type":"block","_key":"seed000u","style":"normal","markDefs":[],"children":[{"_type":"span","_key":"seed000v","text":"This site keeps no accounts and sets no tracking cookies. Hosting infrastructure (Vercel) records standard access logs; submissions through open-call forms go to Tally and are covered by their privacy terms. Write to us to have anything you sent removed.","marks":[]}]}]}
{"_id":"siteSettings","_type":"siteSettings","siteTitle":"DHAKAMYTHOS","manifesto":[{"_type":"block","_key":"seed000w","style":"normal","markDefs":[],"children":[{"_type":"span","_key":"seed000x","text":"dhakamythos is a collective making work about the city that raised us. We publish essays, photographs, films and software pieces — things to read, watch and touch — and we treat all of it as one continuous mythology of Dhaka.","marks":[]}]},{"_type":"block","_key":"seed000y","style":"normal","markDefs":[],"children":[{"_type":"span","_key":"seed000z","text":"Everything here is made to be seen on a phone on a slow connection, because that is where the city reads. Open calls are how we grow; if the work above feels like a language you speak, send us something.","marks":[]}]}],"email":"hello@dhakamythos.com","instagram":"https://instagram.com/dhakamythos","cityLine":"Dhaka, Bangladesh"}
